    "srtp_unprotect_rtcp(srtp_t ctx, const uint8_t *srtcp, size_t srtcp_len, uint8_t *rtcp, size_t *rtcp_len)",
    "srtp_stream_add(srtp_t session, const srtp_policy_t *policy)",
    "srtp_stream_remove(srtp_t session, uint32_t ssrc)",
    "srtp_stream_update(srtp_t session, const srtp_policy_t *policy)",
