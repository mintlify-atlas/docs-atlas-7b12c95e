  "keyFeatures": [
    "RFC 3711 compliant SRTP implementation for RTP encryption and authentication",
    "SRTCP support for securing RTP control protocol traffic",
    "AES-GCM authenticated encryption per RFC 7714",
    "Multiple cipher backends: OpenSSL, NSS, mbedTLS, or built-in",
    "AES-128, AES-192, and AES-256 key sizes with ICM and GCM modes",
    "Master Key Identifier (MKI) support for multi-key sessions",
    "Replay attack protection with configurable window size",
    "Event handler callbacks for key expiry and SSRC collision events",
    "Cross-platform: Linux, macOS, Windows (MSVC/CMake), BSD, Solaris",
    "Build system support: autotools, CMake, and Meson"
  ],
  "publicApiSurface": [
